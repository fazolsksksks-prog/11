-- // EVENTOS DE TECLADO (Corrigido para não ativar no chat)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- O 'gameProcessed' ignora se o jogador estiver digitando no Chat ou em uma Textbox
    if gameProcessed then return end 

    if input.KeyCode == Enum.KeyCode.V then
        alternarMenu()
    elseif input.KeyCode == Enum.KeyCode.E then
        -- O E só funciona se o menu estiver aberto e a aba de config estiver fechada
        if menuAberto and not configAberta then
            acaoAtivar()
        end
    end
end)
