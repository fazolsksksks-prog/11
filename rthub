-- // LÓGICA DO SISTEMA
local menuAberto = false
local configAberta = false
local senhaValidada = false

-- Função para abrir/fechar o menu inteiro com animação
local function alternarMenu()
    menuAberto = not menuAberto
    if menuAberto then
        mainFrame.Size = UDim2.new(0, 340, 0, 0)
        mainFrame.Visible = true
        animar(mainFrame, {Size = UDim2.new(0, 340, 0, 240)}, 0.3)
    else
        local fechar = animar(mainFrame, {Size = UDim2.new(0, 340, 0, 0)}, 0.3)
        fechar.Completed:Connect(function()
            if not menuAberto then mainFrame.Visible = false end
        end)
    end
end

-- Função para deslizar entre Principal e Configurações
local function alternarConfig()
    configAberta = not configAberta
    if configAberta then
        animar(contentContainer, {Position = UDim2.new(-1, 0, 0, 40)}, 0.3)
        btnConfig.TextColor3 = COR_ROXA
    else
        animar(contentContainer, {Position = UDim2.new(0, 0, 0, 40)}, 0.3)
        btnConfig.TextColor3 = Color3.new(1,1,1)
    end
end

local function executarHack()
    local rem = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("UpdateProgress")
    if rem then rem:FireServer(100000000000000) end
end

local function acaoAtivar()
    passBox:ReleaseFocus()
    
    if not senhaValidada then
        if passBox.Text == SENHA_CORRETA then
            senhaValidada = true
            
            -- Animação de sucesso
            animar(passBox, {BackgroundTransparency = 1, TextTransparency = 1}, 0.3)
            task.wait(0.3)
            passBox.Visible = false
            
            animar(btnAtivar, {Position = UDim2.new(0.5, -130, 0.5, -22), BackgroundColor3 = Color3.fromRGB(40, 180, 40)}, 0.3)
            btnAtivar.Text = "✔ AUTENTICADO"
            executarHack()
            
            task.wait(1.5)
            btnAtivar.Text = "EXECUTAR NOVAMENTE"
            animar(btnAtivar, {BackgroundColor3 = COR_ROXA}, 0.3)
            animarBotao(btnAtivar, COR_ROXA, Color3.fromRGB(130, 40, 255)) -- Reseta o hover
        else
            -- Animação de erro (Tremer a caixa de senha)
            btnAtivar.Text = "❌ SENHA INCORRETA"
            btnAtivar.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
            
            local posOriginal = passBox.Position
            for i = 1, 4 do
                passBox.Position = posOriginal + UDim2.new(0, math.random(-5, 5), 0, 0)
                task.wait(0.05)
            end
            passBox.Position = posOriginal
            
            task.wait(1)
            btnAtivar.Text = "ATIVAR SCRIPT"
            btnAtivar.BackgroundColor3 = COR_ROXA
        end
    else
        -- Se a senha já foi validada, apenas executa
        btnAtivar.Text = "EXECUTANDO..."
        executarHack()
        task.wait(0.5)
        btnAtivar.Text = "EXECUTAR NOVAMENTE"
    end
end

